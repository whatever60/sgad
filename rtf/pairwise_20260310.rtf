{\cf1  61  }{\cf5\b def}{\cf2  }{\cf9 score_scale_factor}({\cf2 \par}
{\cf1  62  }    seq1_left_idx: {\cf5 int},{\cf2 \par}
{\cf1  63  }    seq1_right_idx: {\cf5 int},{\cf2 \par}
{\cf1  64  }    seq2_left_idx: {\cf5 int},{\cf2 \par}
{\cf1  65  }    seq2_right_idx: {\cf5 int},{\cf2 \par}
{\cf1  66  }    {\cf7 *},{\cf2 \par}
{\cf1  67  }    seq1_left_free: {\cf5 bool},{\cf2 \par}
{\cf1  68  }    seq1_right_free: {\cf5 bool},{\cf2 \par}
{\cf1  69  }    seq2_left_free: {\cf5 bool},{\cf2 \par}
{\cf1  70  }    seq2_right_free: {\cf5 bool},{\cf2 \par}
{\cf1  71  }) {\cf7 -}{\cf7 >} {\cf5 float}:{\cf2 \par}
{\cf1  72  }{\cf2     }{\cf16\i """\par}
{\cf1  73  }{\cf16\i     Compute the score scaling multiplier for a single alignment column.\par}
{\cf1  74  }{\cf16\i \par}
{\cf1  75  }{\cf16\i     Each of the four sequence-end contributions is:\par}
{\cf1  76  }{\cf16\i         1.0                           if the corresponding *_free flag is True\par}
{\cf1  77  }{\cf16\i         30 / (distance_from_end + 1)  otherwise\par}
{\cf1  78  }{\cf16\i \par}
{\cf1  79  }{\cf16\i     The final factor is the sum of enabled contributions.\par}
{\cf1  80  }{\cf16\i \par}
{\cf1  81  }{\cf16\i     Args:\par}
{\cf1  82  }{\cf16\i         seq1_left_idx: Distance from the seq1 left end or seq1 gap boundary.\par}
{\cf1  83  }{\cf16\i         seq1_right_idx: Distance from the seq1 right end or seq1 gap boundary.\par}
{\cf1  84  }{\cf16\i         seq2_left_idx: Distance from the seq2 left end or seq2 gap boundary.\par}
{\cf1  85  }{\cf16\i         seq2_right_idx: Distance from the seq2 right end or seq2 gap boundary.\par}
{\cf1  86  }{\cf16\i         seq1_left_free: Whether the seq1 left-end contribution is neutralized.\par}
{\cf1  87  }{\cf16\i         seq1_right_free: Whether the seq1 right-end contribution is neutralized.\par}
{\cf1  88  }{\cf16\i         seq2_left_free: Whether the seq2 left-end contribution is neutralized.\par}
{\cf1  89  }{\cf16\i         seq2_right_free: Whether the seq2 right-end contribution is neutralized.\par}
{\cf1  90  }{\cf16\i \par}
{\cf1  91  }{\cf16\i     Returns:\par}
{\cf1  92  }{\cf16\i         Multiplicative score scale for the current alignment column.\par}
{\cf1  93  }{\cf16\i     """}{\cf2 \par}
{\cf1  94  }    penalties {\cf7 =} []{\cf2 \par}
{\cf1  95  }    {\cf5\b if} seq1_left_free:{\cf2 \par}
{\cf1  96  }        penalties{\cf7 .}append({\cf7 1.0} {\cf7 /} (seq1_left_idx {\cf7 +} {\cf7 1})){\cf2 \par}
{\cf1  97  }    {\cf5\b if} seq1_right_free:{\cf2 \par}
{\cf1  98  }        penalties{\cf7 .}append({\cf7 1.0} {\cf7 /} (seq1_right_idx {\cf7 +} {\cf7 1})){\cf2 \par}
{\cf1  99  }    {\cf5\b if} seq2_left_free:{\cf2 \par}
{\cf1 100  }        penalties{\cf7 .}append({\cf7 1.0} {\cf7 /} (seq2_left_idx {\cf7 +} {\cf7 1})){\cf2 \par}
{\cf1 101  }    {\cf5\b if} seq2_right_free:{\cf2 \par}
{\cf1 102  }        penalties{\cf7 .}append({\cf7 1.0} {\cf7 /} (seq2_right_idx {\cf7 +} {\cf7 1})){\cf2 \par}
{\cf1 103  }    {\cf5\b return} {\cf5 sum}(penalties) {\cf5\b if} penalties {\cf5\b else} {\cf7 1.0}{\cf2 \par}
{\cf1 104  }{\cf2 \par}
{\cf1 105  }{\cf2 \par}
