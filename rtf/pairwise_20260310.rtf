{\cf1 111  }    {\cf7 *},{\cf2 \par}
{\cf1 112  }    seq1_left_free: {\cf5 bool},{\cf2 \par}
{\cf1 113  }    seq1_right_free: {\cf5 bool},{\cf2 \par}
{\cf1 114  }    seq2_left_free: {\cf5 bool},{\cf2 \par}
{\cf1 115  }    seq2_right_free: {\cf5 bool},{\cf2 \par}
{\cf1 116  }) {\cf7 -}{\cf7 >} {\cf5 float}:{\cf2 \par}
{\cf1 117  }{\cf2     }{\cf16\i """Disable score scaling by returning 1.0 for every column."""}{\cf2 \par}
{\cf1 118  }    _ {\cf7 =} ({\cf2 \par}
{\cf1 119  }        seq1_left_idx,{\cf2 \par}
{\cf1 120  }        seq1_right_idx,{\cf2 \par}
{\cf1 121  }        seq2_left_idx,{\cf2 \par}
{\cf1 122  }        seq2_right_idx,{\cf2 \par}
{\cf1 123  }        seq1_left_free,{\cf2 \par}
{\cf1 124  }        seq1_right_free,{\cf2 \par}
{\cf1 125  }        seq2_left_free,{\cf2 \par}
{\cf1 126  }        seq2_right_free,{\cf2 \par}
{\cf1 127  }    ){\cf2 \par}
{\cf1 128  }    {\cf5\b return} {\cf7 1.0}{\cf2 \par}
