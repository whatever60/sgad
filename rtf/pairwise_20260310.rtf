{\cf1 131  }{\cf5\b def}{\cf2  }{\cf9 column_score_scale_factor}({\cf2 \par}
{\cf1 132  }    mask: {\cf5 int},{\cf2 \par}
{\cf1 133  }    i_: {\cf5 int},{\cf2 \par}
{\cf1 134  }    j_: {\cf5 int},{\cf2 \par}
{\cf1 135  }    {\cf7 *},{\cf2 \par}
{\cf1 136  }    n: {\cf5 int},{\cf2 \par}
{\cf1 137  }    m: {\cf5 int},{\cf2 \par}
{\cf1 138  }    seq1_left_free: {\cf5 bool},{\cf2 \par}
{\cf1 139  }    seq1_right_free: {\cf5 bool},{\cf2 \par}
{\cf1 140  }    seq2_left_free: {\cf5 bool},{\cf2 \par}
{\cf1 141  }    seq2_right_free: {\cf5 bool},{\cf2 \par}
{\cf1 142  }    score_scale_fn: ScoreScaleFn,{\cf2 \par}
{\cf1 143  }) {\cf7 -}{\cf7 >} {\cf5 float}:{\cf2 \par}
{\cf1 144  }{\cf2     }{\cf16\i """\par}
{\cf1 145  }{\cf16\i     Compute score scaling for a DP column from the selected scaling strategy.\par}
{\cf1 146  }{\cf16\i \par}
{\cf1 147  }{\cf16\i     Mask semantics:\par}
{\cf1 148  }{\cf16\i         0: (x, y)  -> letters from both sequences\par}
{\cf1 149  }{\cf16\i         1: (-, y)  -> gap in seq1\par}
{\cf1 150  }{\cf16\i         2: (x, -)  -> gap in seq2\par}
{\cf1 151  }{\cf16\i \par}
{\cf1 152  }{\cf16\i     For substitution columns, nucleotide positions are used directly.\par}
{\cf1 153  }{\cf16\i     For gap columns, the gapped sequence uses the gap boundary (Option A),\par}
{\cf1 154  }{\cf16\i     while the non-gapped sequence uses the actual nucleotide position.\par}
{\cf1 155  }{\cf16\i \par}
{\cf1 156  }{\cf16\i     Args:\par}
{\cf1 157  }{\cf16\i         mask: Column mask (0, 1, or 2).\par}
{\cf1 158  }{\cf16\i         i_: DP row after emitting the current column.\par}
{\cf1 159  }{\cf16\i         j_: DP column after emitting the current column.\par}
{\cf1 160  }{\cf16\i         n: Length of seq1.\par}
{\cf1 161  }{\cf16\i         m: Length of seq2.\par}
{\cf1 162  }{\cf16\i         seq1_left_free: Whether the seq1 left-end contribution is neutralized.\par}
{\cf1 163  }{\cf16\i         seq1_right_free: Whether the seq1 right-end contribution is neutralized.\par}
{\cf1 164  }{\cf16\i         seq2_left_free: Whether the seq2 left-end contribution is neutralized.\par}
{\cf1 165  }{\cf16\i         seq2_right_free: Whether the seq2 right-end contribution is neutralized.\par}
{\cf1 166  }{\cf16\i \par}
{\cf1 167  }{\cf16\i     Returns:\par}
{\cf1 168  }{\cf16\i         Multiplicative score scale for the current alignment column.\par}
{\cf1 169  }{\cf16\i     """}{\cf2 \par}
{\cf1 170  }    {\cf5\b if} mask {\cf7 ==} {\cf7 0}:{\cf2 \par}
{\cf1 171  }        seq1_left_idx {\cf7 =} i_ {\cf7 -} {\cf7 1}{\cf2 \par}
{\cf1 172  }        seq1_right_idx {\cf7 =} n {\cf7 -} i_{\cf2 \par}
{\cf1 173  }        seq2_left_idx {\cf7 =} j_ {\cf7 -} {\cf7 1}{\cf2 \par}
{\cf1 174  }        seq2_right_idx {\cf7 =} m {\cf7 -} j_{\cf2 \par}
{\cf1 175  }    {\cf5\b elif} mask {\cf7 ==} {\cf7 1}:{\cf2 \par}
{\cf1 176  }        seq1_left_idx {\cf7 =} i_{\cf2 \par}
{\cf1 177  }        seq1_right_idx {\cf7 =} n {\cf7 -} i_{\cf2 \par}
{\cf1 178  }        seq2_left_idx {\cf7 =} j_ {\cf7 -} {\cf7 1}{\cf2 \par}
{\cf1 179  }        seq2_right_idx {\cf7 =} m {\cf7 -} j_{\cf2 \par}
{\cf1 180  }    {\cf5\b elif} mask {\cf7 ==} {\cf7 2}:{\cf2 \par}
{\cf1 181  }        seq1_left_idx {\cf7 =} i_ {\cf7 -} {\cf7 1}{\cf2 \par}
{\cf1 182  }        seq1_right_idx {\cf7 =} n {\cf7 -} i_{\cf2 \par}
{\cf1 183  }        seq2_left_idx {\cf7 =} j_{\cf2 \par}
{\cf1 184  }        seq2_right_idx {\cf7 =} m {\cf7 -} j_{\cf2 \par}
{\cf1 185  }    {\cf5\b else}:{\cf2 \par}
{\cf1 186  }        {\cf5\b raise} {\cf10\b ValueError}({\cf16 f}{\cf16 "}{\cf16 Unsupported mask: }{\cf17\b \{}mask{\cf17\b \}}{\cf16 "}){\cf2 \par}
{\cf1 187  }{\cf2 \par}
{\cf1 188  }    {\cf5\b return} score_scale_fn({\cf2 \par}
{\cf1 189  }        seq1_left_idx,{\cf2 \par}
{\cf1 190  }        seq1_right_idx,{\cf2 \par}
{\cf1 191  }        seq2_left_idx,{\cf2 \par}
{\cf1 192  }        seq2_right_idx,{\cf2 \par}
{\cf1 193  }        seq1_left_free{\cf7 =}seq1_left_free,{\cf2 \par}
{\cf1 194  }        seq1_right_free{\cf7 =}seq1_right_free,{\cf2 \par}
{\cf1 195  }        seq2_left_free{\cf7 =}seq2_left_free,{\cf2 \par}
{\cf1 196  }        seq2_right_free{\cf7 =}seq2_right_free,{\cf2 \par}
{\cf1 197  }    ){\cf2 \par}
{\cf1 198  }{\cf2 \par}
{\cf1 199  }{\cf2 \par}
{\cf1 200  }{\cf5\b def}{\cf2  }{\cf9 needleman_wunsch}({\cf2 \par}
{\cf1 201  }    seq1: {\cf5 str},{\cf2 \par}
{\cf1 202  }    seq2: {\cf5 str},{\cf2 \par}
{\cf1 203  }    {\cf7 *},{\cf2 \par}
{\cf1 204  }    score_matrix: {\cf5 dict}[{\cf5 str}, {\cf5 dict}[{\cf5 str}, {\cf5 int} {\cf7 |} {\cf5 float}]],{\cf2 \par}
{\cf1 205  }    gap_open: {\cf5 int} {\cf7 =} {\cf7 -}{\cf7 5},{\cf2 \par}
{\cf1 206  }    gap_extend: {\cf5 int} {\cf7 =} {\cf7 -}{\cf7 1},{\cf2 \par}
{\cf1 207  }    seq1_left_free: {\cf5 bool} {\cf7 =} {\cf5\b False},{\cf2 \par}
{\cf1 208  }    seq1_right_free: {\cf5 bool} {\cf7 =} {\cf5\b False},{\cf2 \par}
{\cf1 209  }    seq2_left_free: {\cf5 bool} {\cf7 =} {\cf5\b False},{\cf2 \par}
{\cf1 210  }    seq2_right_free: {\cf5 bool} {\cf7 =} {\cf5\b False},{\cf2 \par}
{\cf1 211  }    score_scale_fn: ScoreScaleFn {\cf7 =} score_scale_factor,{\cf2 \par}
{\cf1 212  }) {\cf7 -}{\cf7 >} {\cf5 tuple}[{\cf5 str}, {\cf5 str}, {\cf5 float}]:{\cf2 \par}
{\cf1 213  }{\cf2     }{\cf16\i """\par}
{\cf1 214  }{\cf16\i     Pairwise global alignment (Needleman-Wunsch) with affine gaps and free end-gaps,\par}
{\cf1 215  }{\cf16\i     implemented using 2-bit mask states (the 2D counterpart of the 3D mask approach).\par}
{\cf1 216  }{\cf16\i \par}
{\cf1 217  }{\cf16\i     DP lattice\par}
{\cf1 218  }{\cf16\i     ----------\par}
{\cf1 219  }{\cf16\i     A DP cell (i, j) means we have consumed:\par}
{\cf1 220  }{\cf16\i         - i characters from seq1\par}
{\cf1 221  }{\cf16\i         - j characters from seq2\par}
{\cf1 222  }{\cf16\i \par}
{\cf1 223  }{\cf16\i     Scoring\par}
{\cf1 224  }{\cf16\i     -------\par}
{\cf1 225  }{\cf16\i         - Substitution: lookup in `score_matrix` (dict-of-dicts), multiplied by a\par}
{\cf1 226  }{\cf16\i             score scale returned by `score_scale_fn`.\par}
{\cf1 227  }{\cf16\i     - Gaps: affine (negative scores), also scaled per column by the same\par}
{\cf1 228  }{\cf16\i             score scale:\par}
{\cf1 229  }{\cf16\i           gap_run_score(length=k) = sum(base_gap_col_score * factor_for_that_column)\par}
{\cf1 230  }{\cf16\i \par}
{\cf1 231  }{\cf16\i     Mask state model\par}
{\cf1 232  }{\cf16\i     ----------------\par}
{\cf1 233  }{\cf16\i     Each alignment column emits either a letter or '-' for each sequence. We encode the\par}
{\cf1 234  }{\cf16\i     current column type with a 2-bit mask where a set bit means that sequence is a gap:\par}
{\cf1 235  }{\cf16\i \par}
{\cf1 236  }{\cf16\i         bit0 (value 1): seq1 is a gap in this column\par}
{\cf1 237  }{\cf16\i         bit1 (value 2): seq2 is a gap in this column\par}
{\cf1 238  }{\cf16\i \par}
{\cf1 239  }{\cf16\i     Valid masks are 0..2 and we exclude mask 3 (binary 11) because '--' (all gaps)\par}
{\cf1 240  }{\cf16\i     is an invalid column.\par}
{\cf1 241  }{\cf16\i \par}
{\cf1 242  }{\cf16\i         mask 0 (00): (x, y)   letters from both sequences\par}
{\cf1 243  }{\cf16\i         mask 1 (01): (-, y)   gap in seq1\par}
{\cf1 244  }{\cf16\i         mask 2 (10): (x, -)   gap in seq2\par}
{\cf1 245  }{\cf16\i \par}
{\cf1 246  }{\cf16\i     Each mask implies the DP move (di, dj):\par}
{\cf1 247  }{\cf16\i         di = 0 if (mask & 1) else 1\par}
{\cf1 248  }{\cf16\i         dj = 0 if (mask & 2) else 1\par}
{\cf1 249  }{\cf16\i \par}
{\cf1 250  }{\cf16\i     Affine gaps via mask transitions\par}
{\cf1 251  }{\cf16\i     --------------------------------\par}
{\cf1 252  }{\cf16\i     Affine gaps are handled by comparing the current mask to the previous mask:\par}
{\cf1 253  }{\cf16\i \par}
{\cf1 254  }{\cf16\i     - If seq1 is gapped in current mask:\par}
{\cf1 255  }{\cf16\i         - extend if seq1 was also gapped in previous mask\par}
{\cf1 256  }{\cf16\i         - else open\par}
{\cf1 257  }{\cf16\i     - Likewise for seq2.\par}
{\cf1 258  }{\cf16\i \par}
{\cf1 259  }{\cf16\i     End-free gaps (semiglobal behavior)\par}
{\cf1 260  }{\cf16\i     -----------------------------------\par}
{\cf1 261  }{\cf16\i     End-free gaps are implemented by zeroing the per-column gap penalty when the gap\par}
{\cf1 262  }{\cf16\i     occurs on the corresponding boundary:\par}
{\cf1 263  }{\cf16\i \par}
{\cf1 264  }{\cf16\i         - If seq1_left_free and i == 0 -> gaps in seq1 cost 0 in that column\par}
{\cf1 265  }{\cf16\i         - If seq1_right_free and i == len(seq1) -> gaps in seq1 cost 0 in that column\par}
{\cf1 266  }{\cf16\i         - Similarly for seq2 using j.\par}
{\cf1 267  }{\cf16\i \par}
{\cf1 268  }{\cf16\i     This boundary-based approach keeps free gaps truly terminal with respect to the\par}
{\cf1 269  }{\cf16\i     final alignment string.\par}
{\cf1 270  }{\cf16\i \par}
{\cf1 271  }{\cf16\i     Deterministic tie-breaking\par}
{\cf1 272  }{\cf16\i     --------------------------\par}
{\cf1 273  }{\cf16\i     When multiple transitions have the same score, this implementation is deterministic:\par}
{\cf1 274  }{\cf16\i         - Mask order is fixed as [0, 1, 2].\par}
{\cf1 275  }{\cf16\i         - Previous-state ties keep the first state encountered (strict '>' update).\par}
{\cf1 276  }{\cf16\i         - Final state ties at (n, m) use `np.argmax`, which returns the first maximum.\par}
{\cf1 277  }{\cf16\i     This guarantees reproducible traceback choices across runs.\par}
{\cf1 278  }{\cf16\i \par}
{\cf1 279  }{\cf16\i     Args:\par}
{\cf1 280  }{\cf16\i         seq1: DNA sequence 1.\par}
